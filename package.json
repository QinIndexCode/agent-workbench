{
  "name": "scc-agent-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @scc/shared && npm run build -w @scc/core && npm run build -w @scc/server && npm run build -w @scc/web",
    "dev": "npm run dev -w @scc/server",
    "dev:all": "node scripts/start-dev.js",
    "dev:server": "npm run dev -w @scc/server",
    "dev:web": "npm run dev -w @scc/web",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:docs": "node scripts/check-docs.mjs",
    "test:matrix": "vitest run tests/real-task-matrix/matrix.test.ts",
    "test:stress": "vitest run tests/stress/stress.test.ts",
    "test:web-budgets": "node scripts/check-web-budgets.mjs",
    "smoke:live-model": "npm.cmd run build && node scripts/live-model-smoke.mjs",
    "test:e2e": "npm.cmd run build && playwright test tests/e2e/workbench.spec.ts tests/e2e/flagship-ui.spec.ts && node scripts/check-playwright-results.mjs",
    "test:a11y": "npm.cmd run build && playwright test tests/e2e/accessibility.spec.ts",
    "typecheck": "tsc -b packages/shared packages/core apps/server apps/web",
    "check:no-old-control": "node scripts/check-no-old-control.mjs",
    "quality:full": "node scripts/run-quality-suite.mjs",
    "ci:local": "npm run quality:full"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.28.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}

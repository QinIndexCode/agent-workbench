+/**
+ * Validates that a PATCH request originates from a trusted local origin.
+ * This is important for operations that modify state and should only
+ * be allowed from loopback addresses or trusted browser origins.
+ */
+export function isTrustedLocalPatchRequest(
+  request: IncomingMessage,
+  origin: string | undefined | null
+): boolean {
+  // PATCH requests must come from loopback for security
+  if (!isLoopbackRequest(request)) {
+    return false;
+  }
+
+  // If origin is provided, it must be trusted
+  if (origin) {
+    return isTrustedBrowserOrigin(request, origin);
+  }
+
+  // No origin header means non-browser request from loopback - trusted
+  return true;
+}

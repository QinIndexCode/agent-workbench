{
  "name": "scc-batch-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "Clean rewrite baseline for SCC-Batch backend runtime",
  "dependencies": {
    "@types/blessed": "^0.1.27",
    "blessed": "^0.1.81",
    "pg": "^8.13.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.5.13"
  },
  "scripts": {
    "dev": "npm run start",
    "dev:worker": "npm run start:worker",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "_build:tsc": "tsc -p tsconfig.json",
    "build": "node scripts/build-locked.mjs",
    "test": "npm run build && node --test --test-isolation=none --test-concurrency=1 tests/*.test.cjs",
    "test:postgres": "node scripts/run-postgres-tests.mjs",
    "benchmark": "npm run build && node dist/bin/benchmark.js",
    "workflow-scenarios": "npm run build && node dist/bin/workflow-scenarios.js",
    "breadth-scenarios": "npm run build && node dist/bin/breadth-scenarios.js",
    "flagship-scenarios": "npm run build && node dist/bin/flagship-scenarios.js",
    "general-complex-scenarios": "npm run build && node dist/bin/general-complex-scenarios.js",
    "real-task-completion": "npm run build && node dist/bin/real-task-completion.js",
    "public-capability-parity": "npm run build && node dist/bin/public-capability-parity.js",
    "manual-artifact-audit": "npm run build && node dist/bin/manual-artifact-audit.js",
    "practical-task-acceptance": "npm run build && node dist/bin/practical-task-acceptance.js",
    "practical-manual-audit": "npm run build && node dist/bin/practical-manual-audit.js",
    "practical-live-task-acceptance": "npm run build && node dist/bin/practical-live-task-acceptance.js",
    "practical-live-manual-audit": "npm run build && node dist/bin/practical-live-manual-audit.js",
    "ecommerce-delivery": "npm run build && node dist/bin/ecommerce-delivery.js",
    "ecommerce-readiness": "npm run build && node dist/bin/ecommerce-readiness.js",
    "cli-interaction-transcript": "npm run build && node dist/bin/cli-interaction-transcript.js",
    "runtime-stress-validation": "npm run build && node dist/bin/runtime-stress-validation.js",
    "live-provider-scenarios": "npm run build && node dist/bin/live-provider-scenarios.js",
    "migrate": "npm run build && node dist/bin/migrate.js",
    "start": "npm run build && node dist/bin/server.js",
    "start:worker": "npm run build && node dist/bin/worker.js",
    "cli": "npm run build && node dist/bin/cli.js"
  }
}
